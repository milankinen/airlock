#!/bin/bash
#MISE description="Go wild"
#MISE depends=["build:dev", "build:dev-image"]
#MISE raw=true
#MISE quiet=true
#USAGE arg <feature>
set -euo pipefail

feature="$usage_feature"
root_dir=$(pwd)
ez=$(pwd)/target/debug/ez
tree=.claude/worktrees/$feature
[ -d "$tree" ] || git worktree add ".claude/worktrees/$feature"
[ -f ez.local.toml ] && cp ez.local.toml "$tree/"
[ -d "$tree/target/vm" ] || { mkdir -p "$tree/target/vm" && cp -r target/vm/. "$tree/target/vm/"; }
cd "$tree"
exec "$ez" go --project-cwd="$root_dir" -- claude --dangerously-skip-permissions --effort=high --name=$feature
