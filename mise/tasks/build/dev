#!/bin/bash
#MISE description="Build the CLI binary"
#MISE depends=["build:rootfs", "build:kernel", "build:libkrun"]
#MISE sources=["cli/src/**/*.rs", "cli/Cargo.toml", "Cargo.toml", "Cargo.lock", "sandbox/out/*"]
#MISE outputs=["target/debug/ez"]
set -euo pipefail

cargo build -p ezpez-cli --features dev "$@"

if [[ "$(uname -s)" == "Darwin" ]]; then
  codesign --entitlements entitlements.plist --force -s - target/debug/ez 2>/dev/null || true
fi
