#!/bin/bash
#MISE description="Build the CLI binary"
#MISE depends=["build:rootfs", "build:kernel", "fetch:cloud-hypervisor", "fetch:virtiofsd"]
#MISE sources=["crates/ez/src/**/*.rs", "crates/ez/Cargo.toml", "Cargo.toml", "Cargo.lock", "target/vm/*"]
#MISE outputs=["target/debug/ez"]
set -euo pipefail

cargo build -p ezpez-cli --features dev "$@"

if [[ "$(uname -s)" == "Darwin" ]]; then
  codesign --entitlements entitlements.plist --force -s - target/debug/ez 2>/dev/null || true
fi
