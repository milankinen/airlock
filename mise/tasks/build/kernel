#!/bin/bash
#MISE description="Build the kernel using Docker"
#MISE sources=["vm/kernel/config-*", "vm/kernel/build.sh"]
#MISE outputs=["target/vm/Image"]
set -euo pipefail

HOST_ARCH=$(uname -m)
case "$HOST_ARCH" in
  x86_64)  ARCH=x86_64;  CONFIG=config-x86_64 ;;
  *)       ARCH=arm64;    CONFIG=config-arm64 ;;
esac

echo "Building kernel (${ARCH})..."
mkdir -p target/vm
docker run --rm \
  -e "ARCH=${ARCH}" \
  -e "HOST_UID=$(id -u)" -e "HOST_GID=$(id -g)" \
  -v "$PWD/vm/kernel/${CONFIG}:/config:ro" \
  -v "$PWD/vm/kernel/build.sh:/build.sh:ro" \
  -v "$PWD/target/vm:/out" \
  alpine:3.23 sh -c 'sh /build.sh && chown "$HOST_UID:$HOST_GID" /out/Image'
SIZE=$(du -h target/vm/Image | cut -f1)
echo "Kernel: target/vm/Image (${SIZE})"
