#!/bin/bash
#MISE description="Build libkrun and download libkrunfw"
#MISE sources=["sandbox/libkrun/build.sh", "sandbox/libkrun/netfilter.cfg"]
#MISE outputs=["sandbox/out/libkrun.so", "sandbox/out/libkrunfw.so"]
set -euo pipefail

# libkrun is only needed on Linux
if [[ "$(uname -s)" != "Linux" ]]; then
  echo "Skipping libkrun build (not Linux)"
  mkdir -p sandbox/out
  touch sandbox/out/libkrun.so
  touch sandbox/out/libkrunfw.so
  exit 0
fi

./sandbox/libkrun/build.sh
