#!/bin/bash
#MISE description="Build the rootfs initramfs using Docker"
#MISE depends=["build:supervisor"]
#MISE sources=["vm/rootfs/init", "vm/rootfs/build.sh", "vm/rootfs/ez/oci-run", "vm/rootfs/ez/oci-exec", "target/vm/ezd"]
#MISE outputs=["target/vm/initramfs.gz", "target/vm/rootfs.tar.gz"]
set -euo pipefail

echo "Building rootfs..."
mkdir -p target/vm
docker run --rm \
  -e "HOST_UID=$(id -u)" -e "HOST_GID=$(id -g)" \
  -v "$PWD/vm/rootfs/init:/init-script:ro" \
  -v "$PWD/vm/rootfs/build.sh:/build.sh:ro" \
  -v "$PWD/vm/rootfs/ez/oci-run:/ez-oci-run:ro" \
  -v "$PWD/vm/rootfs/ez/oci-exec:/ez-oci-exec:ro" \
  -v "$PWD/target/vm/ezd:/supervisor-bin:ro" \
  -v "$PWD/target/vm:/out" \
  alpine:3.23 sh -c 'sh /build.sh && chown "$HOST_UID:$HOST_GID" /out/initramfs.gz /out/rootfs.tar.gz'
echo "Rootfs: target/vm/initramfs.gz ($(du -h target/vm/initramfs.gz | cut -f1)), target/vm/rootfs.tar.gz ($(du -h target/vm/rootfs.tar.gz | cut -f1))"
