#!/bin/bash
#MISE description="Build airlockd supervisor for Linux (musl)"
#MISE sources=["app/airlockd/src/**/*.rs", "app/airlockd/Cargo.toml", "app/airlock-common/src/**/*.rs", "app/airlock-common/schema/**/*.capnp", "app/airlockd/builder.dockerfile"]
#MISE outputs=["target/vm/airlockd"]
set -euo pipefail

HOST_ARCH=$(uname -m)
case "$HOST_ARCH" in
  x86_64)  TARGET=x86_64-unknown-linux-musl ;;
  *)       TARGET=aarch64-unknown-linux-musl ;;
esac

mkdir -p target/vm

if [[ "${SUPERVISOR_BUILD_HOST:-}" == "true" ]]; then
  echo "Building airlockd (native, ${TARGET})..."
  cargo build --release -p airlockd --target "${TARGET}"
  cp "target/${TARGET}/release/airlockd" target/vm/airlockd
else
  echo "Preparing airlockd builder..."
  docker build --progress=quiet -t airlockd-builder -f app/airlockd/builder.dockerfile app/airlockd
  echo "Building airlockd (docker, ${TARGET})..."
  [ -f target/vm/airlockd ] && rm target/vm/airlockd
  docker run --rm \
    -e "HOST_UID=$(id -u)" -e "HOST_GID=$(id -g)" \
    -v "$PWD:/workspace:ro" \
    -v "$PWD/target/vm:/out" \
    -v airlock-cargo-cache:/cargo-cache \
    -v airlock-target-cache:/target \
    airlockd-builder sh -c "
      export CARGO_HOME=/cargo-cache
      export RUSTUP_HOME=/cargo-cache
      cd /workspace
      rustup target add ${TARGET}
      cargo build --release -p airlockd --target ${TARGET} --target-dir /target
      cp /target/${TARGET}/release/airlockd /out/airlockd
      chown \${HOST_UID}:\${HOST_GID} /out/airlockd
    "
  [ -f target/vm/airlockd ] || exit 1
fi

echo "airlockd: target/vm/airlockd ($(du -h target/vm/airlockd | cut -f1))"
