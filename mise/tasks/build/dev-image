#!/bin/bash
#MISE description="Build development time sandbox image for mise ez"
#MISE sources=["dev.dockerfile"]
#MISE outputs=["target/ez.dev"]
set -euo pipefail

if [[ "${SKIP_DEV_IMAGE_BUILD:-}" == "true" ]]; then
  echo "Skipping dev image build"
  mkdir -p target
  touch target/ez.dev
  exit 0
fi

docker build -t ez:dev -f dev.dockerfile .
mkdir -p target
touch target/ez.dev