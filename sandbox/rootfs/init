#!/bin/sh
mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev
mkdir -p /dev/pts
mount -t devpts none /dev/pts

hostname ezpez
ip link set lo up 2>/dev/null

# Start supervisor (host↔guest communication via vsock)
/usr/bin/supervisor &
SUPERVISOR_PID=$!

echo "ezpez sandbox ready"

# Interactive shell (debug, will be removed when supervisor handles I/O)
setsid sh -c 'exec sh -l </dev/console >/dev/console 2>/dev/console' 2>/dev/null

# Shell exited — shut down
kill $SUPERVISOR_PID 2>/dev/null
kill -TERM -1 2>/dev/null
sleep 0.2
/sbin/poweroff -f 2>/dev/null
