#!/bin/sh
mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev
mkdir -p /dev/pts
mount -t devpts none /dev/pts
mount -t tmpfs none /tmp
mount -t tmpfs none /run

# cgroups (required by crun)
mkdir -p /sys/fs/cgroup
mount -t cgroup2 none /sys/fs/cgroup

# Mount VirtioFS shares. Tags are passed via kernel cmdline
# as ezpez.shares=bundle,project,mount_0,...
mkdir -p /mnt
shares=$(cat /proc/cmdline | tr ' ' '\n' | grep '^ezpez.shares=' | cut -d= -f2)
IFS=','
for tag in $shares; do
    mkdir -p "/mnt/$tag"
    mount -t virtiofs "$tag" "/mnt/$tag" 2>/dev/null || true
done
unset IFS

hostname ezpez
ip link set lo up 2>/dev/null

/usr/bin/supervisor

kill -TERM -1 2>/dev/null
sleep 0.2
/sbin/poweroff -f 2>/dev/null
